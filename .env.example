# ArcumAI Environment Configuration
# Copy this file to .env and fill in your values
# See doc/ENV_VARIABLES.md for the full reference

# --- Server ---
HOST=0.0.0.0
PORT=8080
ALLOWED_ORIGINS=http://localhost:8080

# --- Secrets (CHANGE THESE) ---
STORAGE_SECRET=change-me-to-a-random-string
CHAINLIT_AUTH_SECRET=change-me-to-a-random-string

# --- Hardware Profile ---
# HIGH_RESOURCE = server with GPU, LOW_RESOURCE = laptop
PROFILE=LOW_RESOURCE

# --- LLM (Ollama) ---
LLM_MODEL=llama3.2:3b
EMBED_MODEL=BAAI/bge-m3
CONTEXT_WINDOW=4096
REQUEST_TIMEOUT=3600.0

# --- Cloud AI (optional) ---
# GOOGLE_API_KEY=your-google-api-key-here
# PROMPT_OPTIMIZATION=local

# --- Privacy ---
ENABLE_NER_MASKING=true
NER_SCORE_THRESHOLD=0.35

# --- Logging ---
LOG_LEVEL=INFO
