<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Connection Settings -->
    <add key="ServerUrl" value="ws://localhost:8080" />
    <add key="UseSecureConnection" value="false" />
    <add key="UserId" value="" />
    <!-- Leave empty to auto-detect from Windows username -->

    <!-- Reconnection Settings -->
    <add key="AutoReconnect" value="true" />
    <add key="ReconnectDelayMs" value="5000" />
    <add key="MaxReconnectAttempts" value="10" />
    <!-- Set to -1 for infinite attempts -->
    <add key="ConnectionTimeoutMs" value="30000" />
    <add key="HeartbeatIntervalMs" value="30000" />
    <!-- Set to 0 to disable heartbeats -->

    <!-- Request Settings -->
    <add key="RequestTimeoutMs" value="60000" />
    <add key="MaxEmailResults" value="10" />
    <add key="EmailPreviewLength" value="200" />

    <!-- Logging Settings -->
    <add key="EnableLogging" value="true" />
    <add key="LogLevel" value="INFO" />
    <!-- Options: DEBUG, INFO, WARNING, ERROR -->
    <add key="LogFilePath" value="" />
    <!-- Leave empty for default: %APPDATA%\ArcumAI\Outlook\logs\plugin.log -->
  </appSettings>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
